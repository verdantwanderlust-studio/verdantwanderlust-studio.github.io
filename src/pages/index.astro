---
import Base from '~/layouts/Base.astro';
import { Image } from 'astro:assets';

// 對齊 Ivy 草稿 image 1:
// 1. About 簡介橫條(全寬,點 → /about)
// 2. 三大入口卡(作品集 / 工作坊 / 商業合作,雙語,target=_blank)
// 3. 作品集卡內極簡 marquee(現:9 張作品縮圖)
// 4. 中段 4 dot carousel(現:Ivy 長型生態照)
// 5. 底部 About / Contact CTA(Ivy 說 footer 設計她還在思考)

// TODO 文案校準:Ivy 是 terrarium / 生態瓶工作室,目前 lede / desc 偏「大型景觀」需要 Ivy 確認用詞
const aboutLede = '景觀設計、庭園諮詢、長期監造維護。我們相信好的庭園,是一段慢慢長出來的關係。';

// 9 張作品縮圖(同 Portfolio)— 給作品集卡的 marquee 用
import t01 from '~/assets/portfolio/01-terrarium-vw.jpg';
import t02 from '~/assets/portfolio/02.jpg';
import t03 from '~/assets/portfolio/03.jpg';
import t04 from '~/assets/portfolio/04.jpg';
import t05 from '~/assets/portfolio/05.jpg';
import t06 from '~/assets/portfolio/06.jpg';
import t07 from '~/assets/portfolio/07-lion-king.png';
import t08 from '~/assets/portfolio/08-lion-king.png';
import t09 from '~/assets/portfolio/09-lion-king.png';

const marqueeImgs = [t01, t02, t03, t04, t05, t06, t07, t08, t09];

// 4 張長型 featured 照
import f01 from '~/assets/featured/01.jpg';
import f02 from '~/assets/featured/02.jpg';
import f03 from '~/assets/featured/03.jpg';
import f04 from '~/assets/featured/04.jpg';

const featuredImgs = [f01, f02, f03, f04];

const entries = [
  {
    href: '/portfolio',
    zh: '作品集',
    en: 'Portfolio',
    desc: '近年案場與作品紀錄',
    hasMarquee: true,
  },
  {
    href: '/courses',
    zh: '工作坊',
    en: 'Workshop',
    desc: '植栽與庭園維護課程',
    hasMarquee: false,
  },
  {
    href: '/contact?type=biz',
    zh: '商業合作',
    en: 'Collaborations',
    desc: '設計案、品牌合作、空間規劃',
    hasMarquee: false,
  },
];
---
<Base
  title="景觀丸藝 / Verdant Wanderlust"
  description="景觀設計、庭園諮詢、長期監造維護。"
>
  <!-- About 簡介橫條 -->
  <a class="about-band" href="/about" transition:name="about-band">
    <div class="column band-inner">
      <p class="kicker">關於 / About</p>
      <h1>介紹景觀丸藝</h1>
      <p class="lede">{aboutLede}</p>
      <span class="more">繼續閱讀 →</span>
    </div>
  </a>

  <!-- 三大入口卡片 -->
  <section class="entries">
    <div class="column">
      <ul class="entry-grid">
        {entries.map(e => (
          <li>
            <a
              href={e.href}
              class="entry"
              target="_blank"
              rel="noopener"
            >
              <div class="thumb">
                {e.hasMarquee ? (
                  <div class="marquee" aria-hidden="true">
                    <div class="marquee-track">
                      {[...marqueeImgs, ...marqueeImgs].map((img, i) => (
                        <span class="m-tile">
                          <Image
                            src={img}
                            alt=""
                            width={160}
                            height={160}
                            densities={[1, 2]}
                            loading={i < 6 ? 'eager' : 'lazy'}
                            class="m-img"
                          />
                        </span>
                      ))}
                    </div>
                  </div>
                ) : (
                  <span class="placeholder" aria-hidden="true">{e.zh.slice(0,1)}</span>
                )}
              </div>
              <h3 class="entry-title">
                <span class="zh">{e.zh}</span>
                <span class="en">{e.en}</span>
              </h3>
              <p class="entry-desc">{e.desc}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 中段 carousel:Ivy 長型照(從 Drive 同步)
       Q2 還沒答完 — 等 Ivy 確認這 4 張要不要配文字 / 換內容方向。
       目前只是靜態擺第 1 張,dot 切換 JS 還沒寫(留給之後 Embla island)。-->
  <section class="featured">
    <div class="column">
      <p class="kicker">FEATURED</p>
      <div class="carousel">
        <div class="slides">
          {featuredImgs.map((img, i) => (
            <div class={`slide ${i === 0 ? 'active' : ''}`} data-i={i + 1}>
              <Image
                src={img}
                alt=""
                width={1400}
                densities={[1, 2]}
                loading={i === 0 ? 'eager' : 'lazy'}
                class="featured-img"
              />
            </div>
          ))}
        </div>
        <div class="dots">
          {featuredImgs.map((_, i) => (
            <button class={`dot ${i === 0 ? 'active' : ''}`} aria-label={`第 ${i + 1} 張`} data-i={i + 1}></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 底部 CTA(Ivy 說 footer 設計她還在思考,先用簡單 CTA 接 footer) -->
  <section class="bottom-cta">
    <div class="column cta-grid">
      <a href="/about" class="cta">
        <span class="cta-kick">關於</span>
        <span class="cta-t">About</span>
      </a>
      <a href="/contact" class="cta">
        <span class="cta-kick">聯繫</span>
        <span class="cta-t">Contact Us</span>
      </a>
    </div>
  </section>
</Base>

<style>
  /* ============ About 簡介橫條 ============ */
  .about-band {
    display: block;
    background: var(--surface-alt);
    border-bottom: 1px solid var(--border);
    padding: var(--s-24) 0;
    color: var(--ink);
    border-top: none;
    transition: background var(--dur-enter) var(--ease);
  }
  .about-band:hover { background: var(--accent-weak); border: none; }
  .band-inner { text-align: left; }
  .about-band .kicker {
    margin: 0 0 var(--s-4) 0;
  }
  .about-band h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, var(--t-hero));
    line-height: var(--lh-tight);
    letter-spacing: var(--track-tight);
    margin: 0 0 var(--s-6) 0;
  }
  .about-band .lede {
    color: var(--muted);
    font-size: var(--t-lg);
    max-width: 640px;
    margin: 0 0 var(--s-6) 0;
  }
  .about-band .more {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  /* ============ 三大入口卡 ============ */
  .entries { padding: var(--s-24) 0; }
  .entry-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-8);
  }
  .entry {
    display: block;
    min-width: 0; /* 防止 marquee 內容把 grid column 撐爆 */
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: var(--s-6);
    background: var(--surface);
    color: var(--ink);
    transition: border-color var(--dur-micro) var(--ease),
                transform var(--dur-enter) var(--ease);
  }
  .entry:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .thumb {
    aspect-ratio: 1 / 1;
    background: var(--surface-alt);
    border-radius: var(--r-sm);
    overflow: hidden;
    margin-bottom: var(--s-4);
    display: flex; align-items: center; justify-content: center;
  }
  .placeholder {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 3.5rem;
    color: var(--border-strong);
  }
  .entry-title {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    margin: 0 0 var(--s-2) 0;
  }
  .entry-title .zh {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-lg);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .entry-title .en {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--subtle);
  }
  .entry-desc {
    margin: 0;
    color: var(--muted);
    font-size: var(--t-sm);
  }

  /* ============ Marquee(極簡執行:慢、無斷縫、hover 暫停)============ */
  .marquee {
    width: 100%; height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .marquee-track {
    display: flex;
    gap: var(--s-3);
    padding: 0 var(--s-3);
    animation: marquee-scroll 60s linear infinite;
    will-change: transform;
  }
  .entry:hover .marquee-track { animation-play-state: paused; }
  .m-tile {
    flex: 0 0 80px;
    height: 80px;
    background: var(--border);
    border-radius: var(--r-sm);
    overflow: hidden;
    display: block;
  }
  .m-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  /* ============ 中段 carousel placeholder ============ */
  .featured { padding: var(--s-16) 0; border-top: 1px solid var(--border); }
  .muted-h {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: var(--t-sm);
    color: var(--subtle);
    margin: var(--s-3) 0 var(--s-8) 0;
    max-width: 720px;
  }
  .carousel {
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: var(--s-6);
    background: var(--surface);
  }
  .slides {
    position: relative;
    margin-bottom: var(--s-6);
    border-radius: var(--r-sm);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--surface-alt);
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--dur-enter) var(--ease);
  }
  .slide.active { opacity: 1; }
  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .dots {
    display: flex; gap: var(--s-2); justify-content: center;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--border-strong);
    border: none;
    cursor: pointer;
    transition: background var(--dur-micro) var(--ease),
                transform var(--dur-micro) var(--ease);
  }
  .dot.active { background: var(--accent); transform: scale(1.3); }
  .dot:hover { background: var(--accent); }

  /* ============ Bottom CTA(About / Contact)============ */
  .bottom-cta { padding: var(--s-12) 0 var(--s-16); border-top: 1px solid var(--border); }
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }
  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--s-12) var(--s-6);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    color: var(--ink);
    transition: background var(--dur-micro) var(--ease),
                border-color var(--dur-micro) var(--ease);
  }
  .cta:hover {
    background: var(--accent-weak);
    border-color: var(--accent);
  }
  .cta-kick {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: var(--s-2);
  }
  .cta-t {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-xl);
    letter-spacing: var(--track-tight);
    color: var(--ink);
  }

  @media (max-width: 720px) {
    .entry-grid { grid-template-columns: 1fr; gap: var(--s-6); }
    .cta-grid { grid-template-columns: 1fr; }
    .about-band { padding: var(--s-16) 0; }
  }
</style>
