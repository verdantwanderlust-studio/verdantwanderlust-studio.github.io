---
/*
  Portfolio Preview v1 — Botanical Specimen Cabinet
  ------------------------------------------------------
  Throwaway 設計 preview,給 Ivy 看「離開 ci-editorial 後 portfolio 可以是什麼樣子」。
  方向來自 2026-05-29 agent team 共識:
    - 暗酒紅底(跟 Ivy 攝影木紋背景同源)
    - Cormorant Garamond serif + Inter Tight body + JetBrains Mono metadata
    - 標本櫃感(編號 VW-2026-XX)、銅金細線、保留 hover flip 但反轉色彩
  正式 site design system Ivy 之後用 claude design 自己長,本檔可隨時刪。
  不繼承 Base layout(那是 light cream nav)— 整頁 dark register。
*/

import { Image } from 'astro:assets';
import logoWhite from '~/assets/logo/wanderlust-mark-white.png';

import img01 from '~/assets/portfolio/01-terrarium-vw.jpg';
import img02 from '~/assets/portfolio/02.jpg';
import img03 from '~/assets/portfolio/03.jpg';
import img04 from '~/assets/portfolio/04.jpg';
import img05 from '~/assets/portfolio/05.jpg';
import img06 from '~/assets/portfolio/06.jpg';
import img07 from '~/assets/portfolio/07-lion-king.png';
import img08 from '~/assets/portfolio/08-lion-king.png';
import img09 from '~/assets/portfolio/09-lion-king.png';

// 編號 + placeholder 詩意名(待 Ivy 替換)
const works = [
  { img: img01, no: 'VW-2026-01', name: '_作品 01_',          name_en: 'Untitled I',   size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。可從植栽選材 / 季節 / 微氣候 / 故事切入。_' },
  { img: img02, no: 'VW-2026-02', name: '_作品 02_',          name_en: 'Untitled II',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img03, no: 'VW-2026-03', name: '_作品 03_',          name_en: 'Untitled III', size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img04, no: 'VW-2026-04', name: '_作品 04_',          name_en: 'Untitled IV',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img05, no: 'VW-2026-05', name: '_作品 05_',          name_en: 'Untitled V',   size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img06, no: 'VW-2026-06', name: '_作品 06_',          name_en: 'Untitled VI',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img07, no: 'VW-LK-I',    name: '獅子王 I',           name_en: 'Lion King I',   size: '_尺寸_',     concept: '_系列作品理念待 Ivy 填寫_' },
  { img: img08, no: 'VW-LK-III',  name: '獅子王 III',         name_en: 'Lion King III', size: '_尺寸_',     concept: '_系列作品理念待 Ivy 填寫_' },
  { img: img09, no: 'VW-LK-IV',   name: '獅子王 IV',          name_en: 'Lion King IV',  size: '_尺寸_',     concept: '_系列作品理念待 Ivy 填寫_' },
];
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Portfolio Preview · 景觀丸藝</title>
  <meta name="description" content="作品集設計預覽 v1 — Botanical Specimen Cabinet" />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- top bar -->
  <header class="topbar">
    <div class="wrap">
      <a href="/" class="brand" aria-label="景觀丸藝">
        <Image
          src={logoWhite}
          alt="景觀丸藝"
          height={36}
          loading="eager"
          densities={[1, 2]}
          class="brand-mark"
        />
      </a>
      <div class="bar-meta">
        <span class="ver">PREVIEW v1</span>
        <span class="dot"></span>
        <span class="title">CINEMATIC GALLERY</span>
        <a href="/portfolio" class="compare">↩ /portfolio 對照</a>
      </div>
    </div>
  </header>

  <!-- hero -->
  <section class="hero">
    <div class="wrap">
      <p class="kicker">SELECTED WORKS · MMXXVI</p>
      <h1 class="display">Portfolio</h1>
      <p class="lede">玻璃內的微縮地景,從採苔、選材、植入到呼吸,九件作品紀錄一段慢的時間。</p>
      <div class="hero-meta">
        <span>九件 · IX WORKS</span>
        <span class="dot"></span>
        <span>VERDANT WANDERLUST</span>
        <span class="dot"></span>
        <span>2024–2026</span>
      </div>
    </div>
  </section>

  <!-- grid -->
  <section class="grid-section">
    <div class="wrap">
      <ul class="grid">
        {works.map(w => (
          <li class="card">
            <div class="flipper">
              <div class="face front">
                <Image
                  src={w.img}
                  alt={w.name}
                  width={900}
                  height={900}
                  densities={[1, 2]}
                  loading="lazy"
                  class="art"
                />
                <div class="caption-strip">
                  <span class="no">{w.no}</span>
                  <span class="name">{w.name}</span>
                </div>
              </div>
              <div class="face back">
                <div class="back-inner">
                  <p class="back-no">{w.no}</p>
                  <h3 class="back-name">{w.name}</h3>
                  <p class="back-name-en">{w.name_en}</p>
                  <hr class="back-rule" />
                  <dl class="back-dl">
                    <dt>尺寸</dt><dd>{w.size}</dd>
                    <dt>理念</dt><dd>{w.concept}</dd>
                  </dl>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- foot caption -->
  <footer class="foot">
    <div class="wrap">
      <p class="foot-line">
        <span class="seal">VW</span>
        手作 · 採集 · 玻璃裡的氣候
      </p>
      <p class="foot-meta">本頁為設計方向預覽 v1,正式 design system 由 Ivy 用 claude design 之後建。</p>
    </div>
  </footer>

<style is:global>
  :root {
    --bg: #1A1416;
    --surface: #221A1D;
    --surface-2: #2B2226;
    --ink: #EDE6D9;
    --ink-muted: #8B8077;
    --ink-faint: #5B524F;
    --accent: #C9A86A;
    --accent-hover: #D9BC7E;
    --border: #3A2F31;
    --border-strong: #564448;

    --font-display: 'Cormorant Garamond', 'Noto Serif TC', serif;
    --font-body: 'Inter Tight', 'Noto Sans TC', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    --ease: cubic-bezier(0.4, 0, 0.2, 1);
  }

  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ============ top bar ============ */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(26, 20, 22, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .topbar .wrap {
    padding-top: 18px;
    padding-bottom: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .brand { display: flex; align-items: center; }
  .brand-mark { display: block; height: 36px; width: auto; opacity: 0.92; }
  .bar-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .bar-meta .ver { color: var(--accent); }
  .bar-meta .dot {
    width: 3px; height: 3px;
    background: var(--ink-faint);
    border-radius: 50%;
  }
  .bar-meta .compare {
    color: var(--ink-muted);
    text-decoration: none;
    padding-left: 16px;
    border-left: 1px solid var(--border);
    transition: color 200ms var(--ease);
  }
  .bar-meta .compare:hover { color: var(--accent); }

  /* ============ hero ============ */
  .hero {
    padding: 120px 0 80px;
    border-bottom: 1px solid var(--border);
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 28px 0;
  }
  .display {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(4.5rem, 12vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 32px 0;
  }
  .lede {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.5;
    color: var(--ink);
    max-width: 540px;
    margin: 0 0 48px 0;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .hero-meta .dot {
    width: 3px; height: 3px;
    background: var(--accent);
    border-radius: 50%;
  }

  /* ============ grid ============ */
  .grid-section { padding: 120px 0 80px; }
  .grid {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 96px 64px;
  }
  .card {
    perspective: 1400px;
    aspect-ratio: 1 / 1.16;
  }
  .flipper {
    position: relative;
    width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 700ms var(--ease);
    cursor: pointer;
  }
  .card:hover .flipper,
  .card:focus-within .flipper {
    transform: rotateY(180deg);
  }
  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
  }

  /* front */
  .front .art {
    flex: 1;
    width: 100%;
    object-fit: cover;
    display: block;
    border: 1px solid var(--border);
  }
  .caption-strip {
    margin-top: 14px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
  }
  .caption-strip .no {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .caption-strip .name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink);
    text-align: right;
  }

  /* back */
  .back {
    background: var(--ink);
    color: #2A2522;
    transform: rotateY(180deg);
    border: 1px solid var(--accent);
    box-shadow: 0 18px 48px rgba(0,0,0,0.45);
  }
  .back-inner {
    padding: 36px 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }
  .back-no {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #9C8550;
    margin: 0;
  }
  .back-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.6rem, 2.5vw, 2.1rem);
    line-height: 1.1;
    color: #1A1416;
    margin: 8px 0 4px 0;
  }
  .back-name-en {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #5B4E40;
    margin: 0 0 18px 0;
  }
  .back-rule {
    width: 32px;
    height: 1px;
    background: #9C8550;
    border: none;
    margin: 0 0 18px 0;
  }
  .back-dl {
    margin: 0;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 8px 16px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.55;
  }
  .back-dl dt {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6F6149;
    padding-top: 3px;
  }
  .back-dl dd {
    margin: 0;
    color: #2A2522;
  }

  /* ============ foot ============ */
  .foot {
    padding: 64px 0 96px;
    border-top: 1px solid var(--border);
    margin-top: 80px;
  }
  .foot .wrap {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 32px;
    flex-wrap: wrap;
  }
  .foot-line {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 50%;
  }
  .foot-meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0;
    max-width: 480px;
  }

  /* ============ responsive ============ */
  @media (max-width: 960px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: 64px 32px; }
    .hero { padding: 80px 0 60px; }
    .grid-section { padding: 80px 0 60px; }
  }
  @media (max-width: 640px) {
    .wrap { padding: 0 20px; }
    .grid { grid-template-columns: 1fr; gap: 48px; }
    .topbar .wrap { gap: 12px; }
    .bar-meta { font-size: 0.62rem; gap: 10px; }
    .bar-meta .compare { padding-left: 10px; }
    .display { letter-spacing: -0.01em; }
    .hero { padding: 60px 0 40px; }
    .hero-meta { font-size: 0.62rem; gap: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flipper { transition: none; }
  }
</style>

</body>
</html>
