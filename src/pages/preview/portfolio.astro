---
/* Portfolio / 作品集 — 照 Ivy 草稿 image 3 + 4
   - Gallery 標題(她劃掉改 PORTFOLIO),在 sticky nav 下方
   - 3×3 九宮格,寬高一致(4/5 直幅,object-fit cover)
   - hover 翻面:正面照片 → 背面「作品說明」(尺寸 / 名稱 / 理念)
   - 背面維持暗調 surface + 銅金邊,不跳白底(Jason feedback)
*/
import PreviewLayout from '~/layouts/PreviewLayout.astro';
import { Image } from 'astro:assets';

import img01 from '~/assets/portfolio/01-terrarium-vw.jpg';
import img02 from '~/assets/portfolio/02.jpg';
import img03 from '~/assets/portfolio/03.jpg';
import img04 from '~/assets/portfolio/04.jpg';
import img05 from '~/assets/portfolio/05.jpg';
import img06 from '~/assets/portfolio/06.jpg';
import img07 from '~/assets/portfolio/07-lion-king.png';
import img08 from '~/assets/portfolio/08-lion-king.png';
import img09 from '~/assets/portfolio/09-lion-king.png';

// TODO Ivy 補:作品名 / 尺寸 / 理念。編號 + 詩意名先佔位。
const works = [
  { img: img01, no: 'VW-01', name: '_作品名_', en: 'Untitled I',   size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫:植栽選材 / 季節 / 微氣候 / 故事。_' },
  { img: img02, no: 'VW-02', name: '_作品名_', en: 'Untitled II',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img03, no: 'VW-03', name: '_作品名_', en: 'Untitled III', size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img04, no: 'VW-04', name: '_作品名_', en: 'Untitled IV',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img05, no: 'VW-05', name: '_作品名_', en: 'Untitled V',   size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img06, no: 'VW-06', name: '_作品名_', en: 'Untitled VI',  size: 'Ø_ × H_ cm', concept: '_作品理念待 Ivy 填寫。_' },
  { img: img07, no: 'LK-I',  name: '獅子王 I',  en: 'Lion King I',   size: '_尺寸_', concept: '_系列作品理念待 Ivy 填寫。_' },
  { img: img08, no: 'LK-III',name: '獅子王 III',en: 'Lion King III', size: '_尺寸_', concept: '_系列作品理念待 Ivy 填寫。_' },
  { img: img09, no: 'LK-IV', name: '獅子王 IV', en: 'Lion King IV',  size: '_尺寸_', concept: '_系列作品理念待 Ivy 填寫。_' },
];
---
<PreviewLayout title="作品集 · 景觀丸藝" active="portfolio">
  <section class="port-head">
    <div class="pv-wrap">
      <p class="pv-kicker">Selected Works · MMXXVI</p>
      <h1 class="pv-display title">Portfolio</h1>
      <p class="sub pv-serif">玻璃裡的微縮地景 — 滑過任一件,翻到背面讀它的尺寸與理念。</p>
    </div>
  </section>

  <section class="grid-sec">
    <div class="pv-wrap">
      <ul class="grid">
        {works.map(w => (
          <li class="card">
            <div class="flipper">
              <div class="face front">
                <Image src={w.img} alt={w.name} width={760} height={950} densities={[1, 2]} loading="lazy" class="art" />
                <span class="no-tag">{w.no}</span>
              </div>
              <div class="face back">
                <div class="back-inner">
                  <p class="b-no">{w.no}</p>
                  <h3 class="b-name">{w.name}</h3>
                  <p class="b-en">{w.en}</p>
                  <hr class="pv-rule" />
                  <dl class="b-dl">
                    <dt>尺寸</dt><dd>{w.size}</dd>
                    <dt>理念</dt><dd>{w.concept}</dd>
                  </dl>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>
</PreviewLayout>

<style>
  .port-head { padding: var(--s-24) 0 var(--s-12); border-bottom: 1px solid var(--border); }
  .title { font-size: clamp(4rem, 11vw, 8rem); margin-bottom: var(--s-6); }
  .sub { font-size: clamp(1.1rem, 2vw, 1.4rem); color: var(--ink); max-width: 540px; margin: 0; }

  .grid-sec { padding: var(--s-20) 0 0; }
  .grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-12) var(--s-8);
  }

  /* 寬高一致:每格 4/5 直幅 */
  .card { perspective: 1500px; aspect-ratio: 4 / 5; }
  .flipper {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform var(--d-slow) var(--ease);
    cursor: pointer;
  }
  .card:hover .flipper, .card:focus-within .flipper { transform: rotateY(180deg); }

  .face {
    position: absolute; inset: 0;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border: 1px solid var(--border); border-radius: var(--r-md); overflow: hidden;
  }

  /* 正面:整格照片,銅金小編號 */
  .front { background: var(--surface); }
  .art { width: 100%; height: 100%; object-fit: cover; display: block; }
  .no-tag {
    position: absolute; left: var(--s-3); bottom: var(--s-3);
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.16em;
    color: var(--ink); background: rgba(26,20,22,0.6); backdrop-filter: blur(4px);
    padding: 3px 8px; border-radius: var(--r-sm); border: 1px solid var(--border-strong);
  }

  /* 背面:暗調 surface + 銅金邊(不跳白底) */
  .back {
    background: var(--surface-2); transform: rotateY(180deg);
    border-color: var(--accent);
  }
  .back-inner { height: 100%; padding: var(--s-8) var(--s-6); display: flex; flex-direction: column; justify-content: center; }
  .b-no { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin: 0; }
  .b-name { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: clamp(1.6rem, 2.4vw, 2.1rem); line-height: 1.05; color: var(--ink); margin: var(--s-2) 0 var(--s-1); }
  .b-en { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-muted); margin: 0; }
  .pv-rule { margin: var(--s-5) 0; }
  .b-dl { margin: 0; display: grid; grid-template-columns: 48px 1fr; gap: var(--s-3) var(--s-4); }
  .b-dl dt { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); padding-top: 4px; }
  .b-dl dd { margin: 0; color: var(--ink); font-size: 0.84rem; line-height: 1.55; }

  @media (max-width: 820px) { .grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-8) var(--s-5); } .title { margin-bottom: var(--s-4); } }
  @media (max-width: 480px) { .grid { grid-template-columns: 1fr; } .card { aspect-ratio: 1 / 1; } }
  @media (prefers-reduced-motion: reduce) { .flipper { transition: none; } }
</style>
