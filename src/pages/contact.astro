---
import Base from '~/layouts/Base.astro';

// workshop 後 Ivy 替換實際資訊
const email = 'hello@verdantwanderlust.com';
const phone = '+886 _ ____ ____';
const address = '_工作室地址 / 服務區域_';

// Google Map embed — Ivy 提供地址後替換
// 用 Google Maps -> 分享 -> 嵌入地圖 拿 src
const mapSrc = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14467.041946953336!2d121.5318!3d25.0330!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjXCsDAxJzU4LjgiTiAxMjHCsDMxJzU0LjUiRQ!5e0!3m2!1szh-TW!2stw';
---
<Base title="聯繫 · 景觀丸藝" description="與景觀丸藝聯絡。">
  <section class="column page">
    <p class="kicker">聯繫 / Contact</p>
    <h1>寫一封信</h1>
    <p class="lede">我們會回。</p>

    <dl class="info">
      <dt>Email</dt>
      <dd><a href={`mailto:${email}`}>{email}</a></dd>

      <dt>電話</dt>
      <dd>{phone}</dd>

      <dt>工作室</dt>
      <dd>{address}</dd>
    </dl>

    <div class="map-wrap">
      <p class="kicker map-kick">位置 / Location</p>
      <div class="map">
        <iframe
          src={mapSrc}
          style="border:0; width:100%; height:100%;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="景觀丸藝 工作室位置"
        ></iframe>
      </div>
    </div>

    <p class="note">
      <!-- Ivy Q3 還在思考要加什麼(電話 / 營業時間 / LINE / 預約方式)— workshop 後補 -->
      _一段簡短的「我們會回信的速度 / 服務區域 / 預約方式」說明_
    </p>
  </section>
</Base>

<style>
  .page { padding: var(--s-16) 0 var(--s-24); max-width: 760px; }
  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-3xl);
    letter-spacing: var(--track-tight);
    line-height: var(--lh-tight);
    margin: var(--s-3) 0 var(--s-6) 0;
  }
  .info {
    margin: var(--s-12) 0 0 0;
    display: grid;
    grid-template-columns: 100px 1fr;
    row-gap: var(--s-6);
    column-gap: var(--s-8);
  }
  dt {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--subtle);
    padding-top: 4px;
  }
  dd {
    margin: 0;
    color: var(--ink);
    font-size: var(--t-lg);
  }
  dd a {
    background-image: linear-gradient(var(--accent), var(--accent));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size var(--dur-enter) var(--ease);
    border-bottom: none;
  }
  dd a:hover { background-size: 100% 1px; border-bottom: none; }

  /* Google Map */
  .map-wrap { margin-top: var(--s-16); }
  .map-kick { margin: 0 0 var(--s-3) 0; }
  .map {
    aspect-ratio: 16 / 9;
    border-radius: var(--r-md);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .note {
    margin-top: var(--s-12);
    color: var(--muted);
    font-size: var(--t-sm);
  }

  @media (max-width: 560px) {
    .info { grid-template-columns: 1fr; }
    dt { padding-top: 0; }
  }
</style>
