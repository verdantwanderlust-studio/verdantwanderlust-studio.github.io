---
import Base from '~/layouts/Base.astro';

// 對齊 Ivy 紅字改動(image 7):
// - 名稱 Gallery → PORTFOLIO
// - 標題在 sticky nav「下面」,不是頂部 banner
// - 背景白色(不是 cream)
// - 3×3 九宮格
// 對齊 image 8:
// - 滑鼠移過去翻轉到背面
// - 背面白色背景 + 作品說明(尺寸 / 名稱 / 理念)

const works = Array.from({ length: 9 }).map((_, i) => ({
  slug: `placeholder-${i + 1}`,
  title: ['大安屋頂花園', '老房苔石庭', '海岸退縮復植', '林口禪庭', '宜蘭水岸案', '工作室自宅', '北投溫泉院落', '南港陽台', '永和書齋庭'][i],
  size: `${20 + i * 8}㎡`,
  concept: '_作品理念待 Ivy 填寫_',
  year: 2023 + (i % 3),
  loc: ['台北','台北','宜蘭','新北','宜蘭','工作室','台北','台北','新北'][i],
}));
---
<Base
  title="Portfolio · 景觀丸藝"
  description="作品集 — 景觀丸藝近期案場。"
>
  <div class="portfolio-page">
    <!-- 標題在 sticky nav 下面 -->
    <header class="port-header">
      <div class="column">
        <p class="kicker">作品集 / Works</p>
        <h1 class="port-title">PORTFOLIO</h1>
      </div>
    </header>

    <!-- 3×3 九宮格 -->
    <section class="grid-section">
      <div class="column">
        <ul class="grid">
          {works.map(w => (
            <li class="card">
              <div class="flipper">
                <!-- 正面:圖片 -->
                <div class="face front" aria-hidden="false">
                  <span class="placeholder">{w.title.slice(0,1)}</span>
                </div>
                <!-- 背面:白底 + 尺寸 / 名稱 / 理念 -->
                <div class="face back">
                  <div class="back-meta">{w.loc} · {w.year}</div>
                  <h3 class="back-title">{w.title}</h3>
                  <dl class="back-dl">
                    <dt>尺寸</dt><dd>{w.size}</dd>
                    <dt>理念</dt><dd>{w.concept}</dd>
                  </dl>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Base>

<style>
  /* Portfolio 全頁白底(覆蓋全站 cream)*/
  .portfolio-page { background: #FFFFFF; min-height: 100vh; }

  /* 標題在 sticky nav 下方 */
  .port-header {
    padding: var(--s-12) 0 var(--s-8);
    border-bottom: 1px solid var(--border);
  }
  .port-header .kicker {
    margin: 0 0 var(--s-3) 0;
  }
  .port-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  /* 3×3 九宮格 */
  .grid-section { padding: var(--s-12) 0 var(--s-24); }
  .grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-6);
  }

  /* 卡片:perspective 給子元素 3D 環境 */
  .card {
    perspective: 1200px;
    aspect-ratio: 1 / 1;
  }

  /* 翻面容器 */
  .flipper {
    position: relative;
    width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 600ms var(--ease);
    cursor: pointer;
  }
  .card:hover .flipper,
  .card:focus-within .flipper {
    transform: rotateY(180deg);
  }

  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--r-md);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  /* 正面:placeholder(workshop 後換照片) */
  .front {
    background: #FAFAFA;
    display: flex; align-items: center; justify-content: center;
  }
  .placeholder {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 4rem;
    color: #E5E5E5;
  }

  /* 背面:白色背景 + 作品說明(Ivy 紅字確認) */
  .back {
    background: #FFFFFF;
    transform: rotateY(180deg);
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .back-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--subtle);
    margin-bottom: var(--s-2);
  }
  .back-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-lg);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 var(--s-4) 0;
  }
  .back-dl {
    margin: 0;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--s-2) var(--s-3);
    font-size: var(--t-sm);
  }
  .back-dl dt {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--subtle);
    padding-top: 3px;
  }
  .back-dl dd {
    margin: 0;
    color: var(--ink);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-4); }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .flipper { transition: none; }
  }
</style>
