---
import Base from '~/layouts/Base.astro';
import { Image } from 'astro:assets';

// 對齊 Ivy 紅字改動(image 7):
// - 名稱 Gallery → PORTFOLIO
// - 標題在 sticky nav「下面」,不是頂部 banner
// - 背景白色(不是 cream)
// - 3×3 九宮格
// 對齊 image 8:
// - 滑鼠移過去翻轉到背面
// - 背面白色背景 + 作品說明(尺寸 / 名稱 / 理念)

// 9 件作品圖(從 Drive 同步):src/assets/portfolio/
import img01 from '~/assets/portfolio/01-terrarium-vw.jpg';
import img02 from '~/assets/portfolio/02.jpg';
import img03 from '~/assets/portfolio/03.jpg';
import img04 from '~/assets/portfolio/04.jpg';
import img05 from '~/assets/portfolio/05.jpg';
import img06 from '~/assets/portfolio/06.jpg';
import img07 from '~/assets/portfolio/07-lion-king.png';
import img08 from '~/assets/portfolio/08-lion-king.png';
import img09 from '~/assets/portfolio/09-lion-king.png';

// TODO Ivy 後續補:作品名稱 / 尺寸 / 理念 / 年份 / 地點
// 目前 title/size 為佔位,只圖正確
const works = [
  { img: img01, title: '_作品 01_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img02, title: '_作品 02_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img03, title: '_作品 03_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img04, title: '_作品 04_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img05, title: '_作品 05_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img06, title: '_作品 06_', size: '_尺寸_', concept: '_作品理念待 Ivy 填寫_', year: 2024, loc: '_系列_' },
  { img: img07, title: 'The Lion King I', size: '_尺寸_', concept: '_系列作品_', year: 2024, loc: 'Lion King 系列' },
  { img: img08, title: 'The Lion King III', size: '_尺寸_', concept: '_系列作品_', year: 2024, loc: 'Lion King 系列' },
  { img: img09, title: 'The Lion King IV', size: '_尺寸_', concept: '_系列作品_', year: 2024, loc: 'Lion King 系列' },
];
---
<Base
  title="Portfolio · 景觀丸藝"
  description="作品集 — 景觀丸藝近期案場。"
>
  <div class="portfolio-page">
    <!-- 標題在 sticky nav 下面 -->
    <header class="port-header">
      <div class="column">
        <p class="kicker">作品集 / Works</p>
        <h1 class="port-title">PORTFOLIO</h1>
      </div>
    </header>

    <!-- 3×3 九宮格 -->
    <section class="grid-section">
      <div class="column">
        <ul class="grid">
          {works.map(w => (
            <li class="card">
              <div class="flipper">
                <!-- 正面:作品照 -->
                <div class="face front" aria-hidden="false">
                  <Image
                    src={w.img}
                    alt={w.title}
                    width={600}
                    height={600}
                    densities={[1, 2]}
                    loading="lazy"
                    class="thumb-img"
                  />
                </div>
                <!-- 背面:白底 + 尺寸 / 名稱 / 理念 -->
                <div class="face back">
                  <div class="back-meta">{w.loc} · {w.year}</div>
                  <h3 class="back-title">{w.title}</h3>
                  <dl class="back-dl">
                    <dt>尺寸</dt><dd>{w.size}</dd>
                    <dt>理念</dt><dd>{w.concept}</dd>
                  </dl>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Base>

<style>
  /* Portfolio 全頁白底(覆蓋全站 cream)*/
  .portfolio-page { background: #FFFFFF; min-height: 100vh; }

  /* 標題在 sticky nav 下方 */
  .port-header {
    padding: var(--s-12) 0 var(--s-8);
    border-bottom: 1px solid var(--border);
  }
  .port-header .kicker {
    margin: 0 0 var(--s-3) 0;
  }
  .port-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  /* 3×3 九宮格 */
  .grid-section { padding: var(--s-12) 0 var(--s-24); }
  .grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-6);
  }

  /* 卡片:perspective 給子元素 3D 環境 */
  .card {
    perspective: 1200px;
    aspect-ratio: 1 / 1;
  }

  /* 翻面容器 */
  .flipper {
    position: relative;
    width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 600ms var(--ease);
    cursor: pointer;
  }
  .card:hover .flipper,
  .card:focus-within .flipper {
    transform: rotateY(180deg);
  }

  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--r-md);
    border: 1px solid var(--border);
    overflow: hidden;
  }

  /* 正面:作品照 */
  .front {
    background: #FAFAFA;
  }
  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 背面:白色背景 + 作品說明(Ivy 紅字確認) */
  .back {
    background: #FFFFFF;
    transform: rotateY(180deg);
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .back-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--subtle);
    margin-bottom: var(--s-2);
  }
  .back-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-lg);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 var(--s-4) 0;
  }
  .back-dl {
    margin: 0;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--s-2) var(--s-3);
    font-size: var(--t-sm);
  }
  .back-dl dt {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--subtle);
    padding-top: 3px;
  }
  .back-dl dd {
    margin: 0;
    color: var(--ink);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-4); }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .flipper { transition: none; }
  }
</style>
