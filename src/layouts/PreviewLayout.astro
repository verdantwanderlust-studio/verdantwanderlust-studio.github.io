---
/*
  PreviewLayout — Botanical Specimen Cabinet(暗酒紅標本櫃)
  ==========================================================
  完整設計 preview 的共用底:dark register + sticky nav + footer。
  方向來自 2026-05-29 agent team 共識,照 Ivy 5 張草稿實作。
  THROWAWAY:正式 design system Ivy 之後用 claude design 自己長,整個 /preview/ 可刪。
  不繼承 Base.astro(那是 light cream nav)。所有 token 在本檔 <style is:global>,5 頁共用。
*/
import { Image } from 'astro:assets';
import logoWhite from '~/assets/logo/wanderlust-mark-white.png';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'about' | 'portfolio' | 'courses' | 'contact';
}
const {
  title = '景觀丸藝 / Verdant Wanderlust',
  description = '玻璃裡的微縮地景 — 生態瓶 · 苔蘚 · 微氣候',
  active = 'home',
} = Astro.props;

// nav 照 Ivy 草稿 image 2:關於 → 作品集 → 詳情 → 購物↗Pinkoi → 聯繫
const links = [
  { key: 'about',     href: '/preview/about',     zh: '關於',   en: 'About' },
  { key: 'portfolio', href: '/preview/portfolio',  zh: '作品集', en: 'Works' },
  { key: 'courses',   href: '/preview/courses',    zh: '詳情',   en: 'Detail' },
  { key: 'shop',      href: 'https://www.pinkoi.com/', zh: '購物', en: 'Shop', external: true },
  { key: 'contact',   href: '/preview/contact',    zh: '聯繫',   en: 'Contact' },
];
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+TC:wght@300;400;500&family=Noto+Serif+TC:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- ============ sticky nav(懸浮展示)============ -->
  <header class="pv-nav">
    <div class="pv-wrap nav-inner">
      <div class="nav-left">
        <a href="/preview" class="brand" aria-label="景觀丸藝 首頁">
          <Image src={logoWhite} alt="景觀丸藝" height={50} loading="eager" densities={[1, 2]} class="brand-mark" />
        </a>
        <div class="socials" aria-label="社群">
          <a href="https://www.facebook.com/" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
        </div>
      </div>
      <nav class="links" aria-label="主選單">
        {links.map(l => (
          <a
            href={l.href}
            class:list={['nav-link', { active: l.key === active }]}
            {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <span class="zh">{l.zh}</span>
            {l.external && <span class="ext" aria-hidden="true">↗</span>}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- ============ footer(草稿:logo + About / Contact Us)============ -->
  <footer class="pv-foot">
    <div class="pv-wrap foot-inner">
      <a href="/preview" class="foot-brand" aria-label="景觀丸藝">
        <Image src={logoWhite} alt="景觀丸藝" height={72} loading="lazy" densities={[1, 2]} class="foot-mark" />
      </a>
      <div class="foot-cta">
        <a href="/preview/about" class="cta">
          <span class="cta-zh">關於</span><span class="cta-en">About</span>
        </a>
        <a href="/preview/contact" class="cta">
          <span class="cta-zh">聯繫</span><span class="cta-en">Contact Us</span>
        </a>
      </div>
      <div class="foot-fine">
        <span class="seal">VW</span>
        <p>景觀丸藝 · Verdant Wanderlust　|　設計方向預覽 · Botanical Specimen Cabinet　|　正式 design system 由 Ivy 用 claude design 之後建</p>
      </div>
    </div>
  </footer>

<style is:global>
  :root {
    /* ===== Botanical Specimen Cabinet — dark register ===== */
    --bg: #1A1416;
    --surface: #221A1D;
    --surface-2: #2B2226;
    --ink: #EDE6D9;
    --ink-muted: #9A8E82;
    --ink-faint: #6B5F5A;
    --accent: #C9A86A;
    --accent-hover: #DBBE83;
    --border: #3A2F31;
    --border-strong: #564448;

    --font-display: 'Cormorant Garamond', 'Noto Serif TC', serif;
    --font-body: 'Inter Tight', 'Noto Sans TC', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    /* spacing */
    --s-1: 4px;  --s-2: 8px;  --s-3: 12px; --s-4: 16px; --s-5: 20px;
    --s-6: 24px; --s-8: 32px; --s-10: 40px; --s-12: 48px; --s-16: 64px;
    --s-20: 80px; --s-24: 96px; --s-32: 128px;

    --maxw: 1200px;
    --r-sm: 2px; --r-md: 4px;
    --ease: cubic-bezier(0.4, 0, 0.2, 1);
    --d-fast: 200ms; --d: 400ms; --d-slow: 700ms;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0; padding: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  a { color: inherit; text-decoration: none; }

  .pv-wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--s-8); }

  /* ===== shared editorial primitives(5 頁共用,保證一致)===== */
  .pv-kicker {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 var(--s-6) 0;
  }
  .pv-display {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    line-height: 0.94;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }
  .pv-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
  }
  .pv-rule { width: 36px; height: 1px; background: var(--accent); border: none; margin: var(--s-6) 0; }

  /* ============ nav ============ */
  .pv-nav {
    position: sticky; top: 0; z-index: 20;
    background: rgba(26, 20, 22, 0.82);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    padding-top: var(--s-4); padding-bottom: var(--s-4);
    display: flex; align-items: center; justify-content: space-between; gap: var(--s-6);
  }
  .nav-left { display: flex; align-items: center; gap: var(--s-5); }
  .brand { display: flex; align-items: center; }
  .brand-mark { display: block; height: 50px; width: auto; opacity: 0.95; }
  .socials { display: flex; gap: var(--s-3); padding-left: var(--s-5); border-left: 1px solid var(--border); }
  .socials a {
    width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    color: var(--ink-muted); border-radius: var(--r-sm); transition: color var(--d-fast) var(--ease);
  }
  .socials a:hover { color: var(--accent); }

  .links { display: flex; gap: var(--s-8); align-items: center; }
  .nav-link {
    position: relative;
    display: inline-flex; align-items: baseline; gap: 3px;
    font-size: 0.98rem; font-weight: 400; color: var(--ink-muted);
    padding: var(--s-1) 0;
    transition: color var(--d-fast) var(--ease);
  }
  .nav-link .zh { letter-spacing: 0.02em; }
  .nav-link .ext { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); }
  .nav-link::after {
    content: ''; position: absolute; left: 0; bottom: -3px;
    width: 0; height: 1px; background: var(--accent); transition: width var(--d) var(--ease);
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link:hover::after, .nav-link.active::after { width: 100%; }
  .nav-link.active { color: var(--accent); }

  /* ============ footer ============ */
  .pv-foot { border-top: 1px solid var(--border); margin-top: var(--s-32); padding: var(--s-24) 0 var(--s-16); }
  .foot-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--s-10); }
  .foot-mark { display: block; height: 72px; width: auto; opacity: 0.9; }
  .foot-cta { display: flex; gap: var(--s-4); width: 100%; max-width: 560px; }
  .cta {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: var(--s-2);
    padding: var(--s-10) var(--s-6);
    border: 1px solid var(--border); border-radius: var(--r-md); background: var(--surface);
    transition: border-color var(--d-fast) var(--ease), background var(--d-fast) var(--ease), transform var(--d) var(--ease);
  }
  .cta:hover { border-color: var(--accent); background: var(--surface-2); transform: translateY(-2px); }
  .cta-zh { font-family: var(--font-display); font-style: italic; font-size: 1.6rem; color: var(--ink); }
  .cta-en { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
  .foot-fine { display: flex; flex-direction: column; align-items: center; gap: var(--s-4); }
  .seal {
    display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px;
    font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent);
    border: 1px solid var(--accent); border-radius: 50%;
  }
  .foot-fine p {
    margin: 0; max-width: 640px;
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ink-faint); line-height: 1.9;
  }

  /* ============ responsive ============ */
  @media (max-width: 820px) {
    .nav-inner { flex-wrap: wrap; gap: var(--s-3); }
    .nav-left { gap: var(--s-3); }
    .brand-mark { height: 40px; }
    .socials { padding-left: var(--s-3); }
    .links { width: 100%; justify-content: space-between; gap: var(--s-2); }
    .nav-link { font-size: 0.88rem; }
  }
  @media (max-width: 560px) {
    .pv-wrap { padding: 0 var(--s-5); }
    .foot-cta { flex-direction: column; }
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    * { animation: none !important; }
  }
</style>
</body>
</html>
